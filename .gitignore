# Steam bootstrap shim source — withheld out of respect for Valve, since it
# encodes internal details of Steam's proprietary client that Valve does not
# publish. See THIRD_PARTY_NOTICES ("Steam Client Bootstrap Shim").
app/src/main/cpp/steambootstrap/steam_bootstrap.c

# Vendored SDL2 headers (fetched for evshim build, not pushed)
app/src/main/cpp/third_party/SDL2/

# Signing material — never commit.
# Note the root `keystore` file IS tracked: it is byte-identical to the one
# upstream GameNative commits, i.e. a shared debug key, not a release secret.
# The real release credentials live in app/keystores/keystore.properties.
keystore.properties
app/keystores/keystore.properties
*.keystore
*.p12
*.jks
